#!/usr/bin/env bash
# Install Catppuccin Mocha theme for bat
set -e

BAT_THEMES="$(bat --config-dir)/themes"
mkdir -p "$BAT_THEMES"

URL="https://github.com/catppuccin/bat/raw/main/themes/Catppuccin%20Mocha.tmTheme"
DEST="$BAT_THEMES/Catppuccin-mocha.tmTheme"

if [[ -f "$DEST" ]]; then
    echo "Catppuccin Mocha already installed for bat"
else
    wget -q "$URL" -O "$DEST"
    bat cache --build
    echo "Catppuccin Mocha installed for bat"
fi
